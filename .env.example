# =============================================================================
# The Vault by Enter Aevum — Environment Variables
# Copy to .env.local and fill in values. Never commit secrets.
# =============================================================================

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="The Vault by Enter Aevum"

# Supabase (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: Aevum Digital checkout handoff (design deposit — no native Stripe in-app yet)
NEXT_PUBLIC_AEVUM_CHECKOUT_URL=https://aevumdigital.co

# Stripe (https://dashboard.stripe.com) — future native checkout
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend (https://resend.com)
RESEND_API_KEY=
RESEND_FROM_EMAIL=commissions@entervault.com

# Admin access (comma-separated emails for bootstrap admin role)
VAULT_ADMIN_EMAILS=

# Optional: Vercel / deployment
# VERCEL_URL is set automatically on Vercel
